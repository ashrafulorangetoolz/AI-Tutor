# ============================================================
# AI Tutor Platform — Environment Variables
# Copy this file to `.env` and fill in real values.
# All AI/payment features fall back to safe MOCK responses when
# the corresponding key is missing, so the app runs without them.
# ============================================================

# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_tutor?schema=public"

# ---- Auth ----
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ---- AI Providers ----
OPENROUTER_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GEMINI_API_KEY=""
OPENAI_API_KEY=""
ELEVENLABS_API_KEY=""
SARVAM_API_KEY=""
GOOGLE_VISION_API_KEY=""

# ---- Payments: bKash ----
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""

# ---- Payments: Nagad ----
NAGAD_MERCHANT_ID=""
NAGAD_MERCHANT_KEY=""

# ---- Payments: Stripe ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---- Feature flags ----
# When set to "true", forces mock mode even if API keys are present.
NEXT_PUBLIC_USE_MOCK_AI="true"
